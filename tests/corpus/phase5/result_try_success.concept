module Main;

must_use enum ParseIntResult {
    Ok(int value),
    Err(int code),
};

ParseIntResult parseInt(int value) {
    return ParseIntResult::Ok(value);
}

ParseIntResult plusTwo(int value) {
    int parsed = try parseInt(value);
    return ParseIntResult::Ok(parsed + 2);
}

int main() {
    ParseIntResult result = plusTwo(5);
    match (result) {
        ParseIntResult::Ok(value) => return value;
        ParseIntResult::Err(code) => return code;
    }
}
