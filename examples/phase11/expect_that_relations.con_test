module Examples.Phase11.ExpectThatRelations;

import Core.Test;

bool IsEven(int value) {
    return value % 2 == 0;
}

[Fact]
void UsesPrimitiveRelations() {
    Expect.That(
        IsEven(4),
        Is.True(),
        "four should be classified as even"
    );

    Expect.That(
        IsEven(5),
        Is.False(),
        "five should not be classified as even"
    );

    Expect.That(
        6 * 7,
        Is.EqualTo(42),
        "multiplication should produce the expected integer result"
    );

    Expect.That(
        IsEven(8),
        Is.EqualTo(true),
        "EqualTo(bool) should compare primitive boolean relation values"
    );
}
