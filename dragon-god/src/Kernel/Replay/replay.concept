module DragonGod.Kernel.Replay;

import DragonGod.Kernel.Core;
import DragonGod.Kernel.Memory;
import DragonGod.Kernel.Mind;
import DragonGod.Kernel.Automata;
import DragonGod.Kernel.Events;
import DragonGod.Kernel.Actuation;
import DragonGod.Kernel.Trace;

// DG10 Replay v0: deterministic fixed-slot integer input stream. Replay is
// not persistence, checkpointing, file I/O, JSON, binary serialization, an
// external input adapter, scheduler, async runtime, or compiler hook.
enum ReplayEvent {
    Empty,
    Advance(int ticks),
    WorldMemoryWriteInt(DragonGod.Kernel.Memory.MemoryKeyInt key, int value),
    AgentMemoryWriteInt(DragonGod.Kernel.Memory.MemoryKeyInt key, int value),
    EventPushInt(DragonGod.Kernel.Events.EventTypeId eventType, int value),
    ActuationComplete(DragonGod.Kernel.Core.ActuationId id, DragonGod.Kernel.Core.Reason reason),
    ActuationFail(DragonGod.Kernel.Core.ActuationId id, DragonGod.Kernel.Core.Reason reason),
    TraceMark(DragonGod.Kernel.Core.Reason reason),
    RngSeed(int seed),
};

struct ReplayLog {
    FixedBuffer<ReplayEvent, 4> events;
};

struct ReplayDriver {
    int cursor;
    DragonGod.Kernel.Mind.World world;
    DragonGod.Kernel.Mind.Agent agent;
    DragonGod.Kernel.Events.EventBus events;
    DragonGod.Kernel.Actuation.ActuatorHost actuator;
    DragonGod.Kernel.Trace.TraceRecorder trace;
    int rngSeed;
};

ReplayEvent replayEmptyEvent() { return ReplayEvent::Empty; }

ReplayLog replayLogEmpty() {
    return ReplayLog { events: fixedBufferEmpty<ReplayEvent, 4>() };
}

int replayLogCount(ReplayLog log) { return Len(log.events); }

ReplayEvent replayLogAt(ReplayLog log, int index) {
    if (index >= replayLogCount(log)) { panic("DragonGod.Replay index out of range"); }
    return log.events[index];
}

void replayPush(mut ReplayLog& log, ReplayEvent event) {
    if (replayLogCount(log) >= Capacity(log.events)) { panic("DragonGod.Replay capacity exceeded"); }
    fixedBufferAppend(log.events, event);
}

ReplayDriver replayDriver(DragonGod.Kernel.Mind.World world, DragonGod.Kernel.Mind.Agent agent, DragonGod.Kernel.Events.EventBus events, DragonGod.Kernel.Actuation.ActuatorHost actuator, DragonGod.Kernel.Trace.TraceRecorder trace) {
    return ReplayDriver { cursor: 0, world: world, agent: agent, events: events, actuator: actuator, trace: trace, rngSeed: 0 };
}

ReplayDriver replayDriverEmpty() {
    return replayDriver(
        DragonGod.Kernel.Mind.World { clock: DragonGod.Kernel.Core.Clock { tick: 0 }, memory: DragonGod.Kernel.Memory.memoryEmpty() },
        DragonGod.Kernel.Mind.Agent { id: DragonGod.Kernel.Core.AgentId { value: 0 }, memory: DragonGod.Kernel.Memory.memoryEmpty(), mind: DragonGod.Kernel.Mind.mindEmpty() },
        DragonGod.Kernel.Events.eventBusEmpty(),
        DragonGod.Kernel.Actuation.actuatorHostEmpty(),
        DragonGod.Kernel.Trace.traceRecorderEmpty()
    );
}

bool replayApplyNext(mut ReplayDriver& driver, ReplayLog log) {
    if (driver.cursor >= replayLogCount(log)) { return false; }
    ReplayEvent event = replayLogAt(log, driver.cursor);
    driver.cursor = driver.cursor + 1;

    match (event) {
        ReplayEvent::Empty => { return true; }
        ReplayEvent::Advance(ticks) => { driver.world.clock.tick = driver.world.clock.tick + ticks; return true; }
        ReplayEvent::WorldMemoryWriteInt(key, value) => { DragonGod.Kernel.Memory.memoryWrite(driver.world.memory&, key, value); return true; }
        ReplayEvent::AgentMemoryWriteInt(key, value) => { DragonGod.Kernel.Memory.memoryWrite(driver.agent.memory&, key, value); return true; }
        ReplayEvent::EventPushInt(eventType, value) => { discard DragonGod.Kernel.Events.eventPush(driver.events&, eventType, DragonGod.Kernel.Events.eventPayloadInt(value)); return true; }
        ReplayEvent::ActuationComplete(id, reason) => { DragonGod.Kernel.Actuation.actuatorComplete(driver.actuator&, id, reason); return true; }
        ReplayEvent::ActuationFail(id, reason) => { DragonGod.Kernel.Actuation.actuatorFail(driver.actuator&, id, reason); return true; }
        ReplayEvent::TraceMark(reason) => { DragonGod.Kernel.Trace.traceEnter(driver.trace&, DragonGod.Kernel.Core.StateId { value: reason.code }, driver.world.clock.tick, reason); return true; }
        ReplayEvent::RngSeed(seed) => { driver.rngSeed = seed; return true; }
    }
}

int replayApplyAll(mut ReplayDriver& driver, ReplayLog log) {
    int applied = 0;
    if (replayApplyNext(driver&, log)) { applied = applied + 1; }
    if (replayApplyNext(driver&, log)) { applied = applied + 1; }
    if (replayApplyNext(driver&, log)) { applied = applied + 1; }
    if (replayApplyNext(driver&, log)) { applied = applied + 1; }
    return applied;
}
