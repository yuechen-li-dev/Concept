=== source ===
module Main;

marker concept Copy<T>;

struct Vec2 {
    int x;
    int y;
};

impl Copy<Vec2>;

int main() {
    Vec2 v = Vec2 { x: 1, y: 2 };
    v = Vec2 { x: 20, y: 22 };

    return v.x + v.y;
}

