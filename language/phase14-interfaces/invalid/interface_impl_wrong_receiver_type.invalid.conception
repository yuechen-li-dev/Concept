=== source ===
module Interfaces;

interface Writer {
    void Write(int value);
};

struct ConsoleWriter {
    int handle;
};

struct OtherWriter {
    int handle;
};

impl Writer<ConsoleWriter> {
    void Write(mut OtherWriter& self, int value) {
    }
}

