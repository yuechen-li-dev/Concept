=== source ===
module Main;

interface Writer {
    void Write(int value);
};

struct ConsoleWriter {
    int handle;
};

struct Other {
    int x;
};

impl Writer<Other> {
    void Write(mut Other& self, int value) {
    }
}

void Emit(mut dyn Writer& writer) {
}

int main() {
    ConsoleWriter writer = ConsoleWriter { handle: 1 };
    Emit(writer);
    return 0;
}

