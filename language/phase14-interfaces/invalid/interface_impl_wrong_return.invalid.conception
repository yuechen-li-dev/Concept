=== source ===
module Interfaces;

interface Writer {
    void Write(int value);
};

struct ConsoleWriter {
    int handle;
};

impl Writer<ConsoleWriter> {
    int Write(mut ConsoleWriter& self, int value) {
        return value;
    }
}

