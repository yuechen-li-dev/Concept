=== source ===
module Interfaces;

interface Writer {
    void Write(int value);
    bool Flush(bool force);
};

struct ConsoleWriter {
    int handle;
};

impl Writer<ConsoleWriter> {
    void Write(mut ConsoleWriter& self, int value) {
    }

    bool Flush(mut ConsoleWriter& self, bool force) {
        return force;
    }
}

int main() {
    return 0;
}
