=== source ===
module Main;

interface Sink {
    void Put(int value);
};

struct Counter {
    int value;
};

impl Sink<Counter> {
    void Put(mut Counter& self, int value) {
        return;
    }
}

void Emit(mut dyn Sink& sink) {
    sink.Put(7);
}

int main() {
    Counter counter = Counter { value: 0 };
    Emit(counter);
    return 7;
}

