module Main;

interface Writer {
    void Write(int value);
};

struct ConsoleWriter {
    int handle;
};

impl Writer<ConsoleWriter> {
    void Write(mut ConsoleWriter& self, int value) {
    }
}

void EmitBoth(mut dyn Writer& first, int value, mut dyn Writer& second) {
}

int main() {
    ConsoleWriter left = ConsoleWriter { handle: 1 };
    ConsoleWriter right = ConsoleWriter { handle: 2 };
    EmitBoth(left, 7, right);
    return 0;
}
