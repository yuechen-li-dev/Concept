# name: phase5 try result mismatch
# phase: check
# check: hir
# expect: fail
# diagnostics: CON0052

=== source ===
module Main;

must_use enum ParseIntResult {
    Ok(int value),
    Err(int code),
};

must_use enum OtherResult {
    Ok(int value),
    Err(int code),
};

ParseIntResult parseInt(int value) {
    return ParseIntResult::Ok(value);
}

OtherResult bad() {
    int value = try parseInt(1);
    return OtherResult::Ok(value);
}

int main() {
    return 0;
}
