=== source ===
module Main;

enum PairResult { Ok(int left, int right), Err(int code), };

int main() {
    PairResult pair = PairResult::Ok(1, 2);
    match (pair) {
        PairResult::Ok(left) => return left;
        _ => return 0;
    }
}

