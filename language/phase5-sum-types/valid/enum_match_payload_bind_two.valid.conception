# name: phase5 enum match payload bind two
# phase: run
# expect: pass

=== source ===
module Main;

enum PairResult {
    Ok(int left, int right),
    Err(int code),
};

int main() {
    PairResult pair = PairResult::Ok(4, 5);
    match (pair) {
        PairResult::Ok(left, right) => return left + right;
        PairResult::Err(code) => return code;
    }
}

