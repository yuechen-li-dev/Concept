module Main;

must_use enum ParseResult {
    Ok(int value),
    Err(int code),
};

int main() {
    ParseResult result = ParseResult::Ok(16);
    match (result) {
        ParseResult::Ok(value) => return value;
        ParseResult::Err(code) => return code;
    }
}

