=== source ===
module Main;

must_use enum ParseIntResult {
    Ok(int value),
    Err(int code),
};

ParseIntResult parseInt(int value) {
    return ParseIntResult::Ok(value);
}

ParseIntResult addTwo(int value) {
    return ParseIntResult::Ok((try parseInt(value)) + 2);
}

int main() {
    ParseIntResult result = addTwo(15);
    match (result) {
        ParseIntResult::Ok(value) => return value;
        ParseIntResult::Err(code) => return code;
    }
}

