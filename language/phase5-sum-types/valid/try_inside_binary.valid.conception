=== source ===
module Main;

must_use enum ParseIntResult {
    Ok(int value),
    Err(int code),
};

ParseIntResult parseInt(int value) {
    return ParseIntResult::Ok(value);
}

ParseIntResult addOne(int value) {
    return ParseIntResult::Ok(1 + try parseInt(value));
}

int main() {
    ParseIntResult result = addOne(6);
    match (result) {
        ParseIntResult::Ok(value) => return value;
        ParseIntResult::Err(code) => return code;
    }
}

