# name: phase5 result try failure run
# phase: run
# expect: pass

=== source ===
module Main;

must_use enum ParseIntResult {
    Ok(int value),
    Err(int code),
};

ParseIntResult parseInt(int value) {
    if (value == 0) {
        return ParseIntResult::Err(12);
    }
    return ParseIntResult::Ok(value);
}

ParseIntResult addChecked(int left, int right) {
    int a = try parseInt(left);
    int b = try parseInt(right);
    return ParseIntResult::Ok(a + b);
}

int main() {
    ParseIntResult result = addChecked(5, 0);
    match (result) {
        ParseIntResult::Ok(value) => return value;
        ParseIntResult::Err(code) => return code;
    }
}

=== run ===
exit_code: 12
