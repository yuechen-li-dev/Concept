# name: compile-time function while sum run
# phase: run
# expect: pass

=== source ===
module Main;

comptime int sumTo(int n) {
    int i = 0;
    int total = 0;

    while (i <= n) {
        total = total + i;
        i = i + 1;
    }

    return total;
}

int main() {
    return comptime sumTo(9);
}

=== run ===
exit_code: 45
