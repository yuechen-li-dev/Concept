module Main;

enum Mode {
    Fast,
    Slow,
}

Mode choose(bool hot) {
    return decide Mode {
        Fast when hot score 10;
        Fast score 0;
        Slow score -1;
    };
}

int main() {
    Mode mode = choose(true);
    return 0;
}
