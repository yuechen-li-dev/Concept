# name: yield keeps machine incomplete run
# phase: run
# expect: pass

=== source ===
module Main;

machine Waiter {
    state Waiting {
        yield;
    }
}

int main() {
    Waiter w = Waiter();
    Step(w);

    if (Complete(w)) {
        return 1;
    }

    return 0;
}

