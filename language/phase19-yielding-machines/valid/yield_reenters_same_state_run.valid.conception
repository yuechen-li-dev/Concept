# name: yield reenters same state run
# phase: run
# expect: pass

=== source ===
module Main;

machine Child -> int {
    state First { transition Second; }
    state Second { return 2; }
}

machine Parent -> int {
    Child child;

    state Waiting {
        Step(child);

        if (!Complete(child)) {
            yield;
        }

        return Result(child);
    }
}

int main() {
    Parent p = Parent();
    Step(p);

    if (Complete(p)) {
        return 99;
    }

    Step(p);
    return Result(p);
}

=== run ===
exit_code: 2
