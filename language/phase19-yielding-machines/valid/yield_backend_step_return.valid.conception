=== source ===
module Main;

machine Waiter {
    state Waiting {
        yield;
    }
}

machine MaybeYield(bool ready) -> int {
    state Start {
        if (!ready) {
            yield;
        }

        return 7;
    }
}

int main() {
    Waiter w = Waiter();
    Step(w);
    MaybeYield m = MaybeYield(true);
    Step(m);
    return Result(m);
}

