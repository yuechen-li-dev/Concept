# name: yield transition decide run
# phase: run
# expect: pass

=== source ===
module Main;

machine Child -> int {
    state Start { transition Done; }
    state Done { return 7; }
}

machine Parent -> int {
    Child child;

    state Waiting {
        Step(child);

        if (!Complete(child)) {
            yield;
        }

        transition decide {
            Done when Complete(child) score 10;
            Retry score 0;
        };
    }

    state Retry { return 0; }
    state Done { return Result(child); }
}

int main() {
    Parent p = Parent();
    Step(p);

    if (Complete(p)) {
        return 99;
    }

    Step(p);
    Step(p);
    return Result(p);
}

=== run ===
exit_code: 7
