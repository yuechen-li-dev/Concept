=== source ===
module Main;

machine Choose -> int {
    state Start {
        transition decide {
            Low score 1;
            High score 5;
        };
    }
    state Low { return 1; }
    state High { return 5; }
}

int main() {
    Choose c = Choose();
    Step(c);
    Step(c);
    return Result(c);
}

