=== source ===
module Main;

machine Choose(bool canHigh, int highScore) -> int {
    state Start {
        transition decide {
            High when canHigh score highScore;
            Low score 1;
        };
    }
    state High { return 2; }
    state Low { return 1; }
}

int main() {
    Choose c = Choose(true, 9);
    Step(c);
    Step(c);
    return Result(c);
}

