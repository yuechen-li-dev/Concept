# name: integration phase18 backend shape
# phase: backend-c
# expect: pass

=== source ===
module Main;

machine Child { state Start { return 7; } }

machine Controller(bool preferDone) {
    Child child;
    state Start { Step(child); transition Check; }
    state Check {
        transition match (Complete(child)) {
            true => Decide;
            false => Start;
        };
    }
    state Decide {
        int childState = State(child);
        transition decide {
            Done when preferDone score 10;
            Observe score childState;
        };
    }
    state Observe { return State(child); }
    state Done { return Result(child); }
}

int main() {
    Controller c = Controller(true);
    Step(c);
    Step(c);
    Step(c);
    Step(c);
    return Result(c);
}

