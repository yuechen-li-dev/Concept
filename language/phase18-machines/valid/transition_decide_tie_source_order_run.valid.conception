module Main;

machine Choose -> int {
    state Start {
        transition decide {
            First score 10;
            Second score 10;
        };
    }
    state First { return 1; }
    state Second { return 2; }
}

int main() {
    Choose c = Choose();
    Step(c);
    Step(c);
    return Result(c);
}

