# name: nested machine operations backend
# phase: backend-c
# expect: pass

=== source ===
module Main;

machine Child { state Start { return 7; } }

machine Parent {
    Child child;
    state Start { Step(child); transition Done; }
    state Done {
        if (Complete(child)) { return Result(child); }
        return 0;
    }
}

int main() {
    Parent p = Parent();
    Step(p);
    Step(p);
    return Result(p);
}

