=== source ===
module Main;

machine Choose(bool canHigh) -> int {
    state Start {
        transition decide {
            High when canHigh score 100;
            Low score 1;
        };
    }
    state High { return 100; }
    state Low { return 1; }
}

int main() {
    Choose c = Choose(false);
    Step(c);
    Step(c);
    return Result(c);
}

