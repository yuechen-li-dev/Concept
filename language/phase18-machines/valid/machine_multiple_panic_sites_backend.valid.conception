# name: machine multiple panic sites backend
# phase: backend-c
# expect: pass

=== source ===
module Main;

machine Choose -> int {
    state Start {
        transition decide {
            Done when false score 1;
        };
    }
    state Done { return 1; }
}

machine Simple() -> int {
    state Start { return 3; }
}

int main() {
    Simple s = Simple();
    int value = Result(s);
    Choose c = Choose();
    Step(c);
    assert(false, "assert reason");
    panic("manual reason");
    return value;
}

