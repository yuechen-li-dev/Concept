=== source ===
module Main;

machine Child { state Start { transition Done; } state Done { return 4; } }

machine Parent {
    Child child;
    state Start { return State(child); }
}

int main() {
    Parent p = Parent();
    int a = State(p);
    Step(p);
    return a + Result(p);
}

