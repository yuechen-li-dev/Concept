module Example;

machine Brain(bool active, int activeScore) -> int {
    state Decide {
        transition decide {
            Active when active score activeScore;
            Idle score 0;
        };
    }

    state Active {
        return 1;
    }

    state Idle {
        return 0;
    }
}

