=== source ===
module Example;

machine Brain(bool canAttack, int attackScore) -> int {
    state Decide {
        transition decide {
            Attack when canAttack score attackScore;
            Idle score 0;
        };
    }

    state Attack {
        return 1;
    }

    state Idle {
        return 0;
    }
}

