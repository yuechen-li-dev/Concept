=== source ===
module Example;

machine Resettable(bool reset, int resetScore) -> int {
    state Start {
        return 0;
    }

    state Decide {
        transition decide {
            Start when reset score resetScore;
            Done score 0;
        };
    }

    state Done {
        return 1;
    }
}

