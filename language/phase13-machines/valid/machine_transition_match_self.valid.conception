# name: machine transition match self
# phase: parse
# expect: pass

=== source ===
module Example;

machine Spinner(int tick) -> int {
    state Start {
        transition match (tick) {
            0 => Start;
            _ => Done;
        };
    }

    state Done {
        return 0;
    }
}

