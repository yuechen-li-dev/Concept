=== source ===
module Example;

machine Spinner(bool keepGoing, int scoreValue) -> int {
    state Spin {
        transition decide {
            Spin when keepGoing score scoreValue;
            Done score 0;
        };
    }

    state Done {
        return 0;
    }
}

