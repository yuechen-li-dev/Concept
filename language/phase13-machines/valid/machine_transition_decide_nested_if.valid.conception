=== source ===
module Example;

machine Flow(bool ready, int readyScore) -> int {
    state Start {
        if (ready) {
            transition decide {
                Done when ready score readyScore;
                Start score 0;
            };
        }
    }

    state Done {
        return 1;
    }
}

