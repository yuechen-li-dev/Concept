# name: machine transition decide when conditions
# phase: parse
# expect: pass

=== source ===
module Example;

machine Brain(bool canAttack, bool canHeal, int attackScore, int healScore) -> int {
    state Decide {
        transition decide {
            Attack when canAttack && attackScore > 0 score attackScore;
            Heal when canHeal || healScore > 10 score healScore;
            Idle score 0;
        };
    }

    state Attack {
        return 1;
    }

    state Heal {
        return 2;
    }

    state Idle {
        return 0;
    }
}

