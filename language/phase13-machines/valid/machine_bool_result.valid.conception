=== source ===
module Main;

machine Toggle() -> bool {
    state Off {
        transition On;
    }

    state On {
        return true;
    }
}

int main() {
    Toggle t = Toggle();
    Step(t);
    Step(t);
    if (Result(t)) {
        return 0;
    }
    return 1;
}

