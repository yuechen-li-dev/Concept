# name: machine transition match nested if
# phase: parse
# expect: pass

=== source ===
module Example;

machine Flow(bool ready, int code) -> int {
    state Start {
        if (ready) {
            transition match (code) {
                0 => Done;
                _ => Error;
            };
        }
    }

    state Done {
        return 1;
    }

    state Error {
        return -1;
    }
}

