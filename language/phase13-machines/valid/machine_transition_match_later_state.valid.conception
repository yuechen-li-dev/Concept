# name: machine transition match later state
# phase: parse
# expect: pass

=== source ===
module Example;

machine Flow(int code) -> int {
    state Start {
        transition match (code) {
            0 => Done;
            _ => Error;
        };
    }

    state Done {
        return 1;
    }

    state Error {
        return -1;
    }
}

