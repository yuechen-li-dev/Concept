# name: machine transition decide basic
# phase: parse
# expect: pass

=== source ===
module Example;

machine Brain(bool canAttack, bool canHeal, bool lowHealth, int attackScore, int healScore, int fleeScore) -> int {
    state Decide {
        transition decide {
            Attack when canAttack score attackScore;
            Heal when canHeal score healScore;
            Flee when lowHealth score fleeScore;
            Idle score 0;
        };
    }

    state Attack {
        return 1;
    }

    state Heal {
        return 2;
    }

    state Flee {
        return 3;
    }

    state Idle {
        return 0;
    }
}

