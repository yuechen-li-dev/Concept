# name: machine complete result
# phase: run
# expect: pass

=== source ===
module Main;

machine Door() -> int {
    state Closed {
        transition Open;
    }

    state Open {
        return 3;
    }
}

int main() {
    Door m = Door();
    if (Complete(m)) {
        return 1;
    }
    Step(m);
    if (Complete(m)) {
        return 2;
    }
    Step(m);
    if (!Complete(m)) {
        return 4;
    }
    return Result(m);
}

=== run ===
exit_code: 3
