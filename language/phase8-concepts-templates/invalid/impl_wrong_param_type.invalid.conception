# name: impl wrong param type
# phase: check
# check: hir
# expect: fail

=== source ===
module Main;

concept Equatable<T> {
    bool equals(T left, T right);
};

struct Vec2 {
    int x;
};

impl Equatable<Vec2> {
    bool equals(int left, Vec2 right) {
        return false;
    }
}

