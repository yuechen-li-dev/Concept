# name: impl wrong return type
# phase: check
# check: hir
# expect: fail

=== source ===
module Main;

concept Equatable<T> {
    bool equals(T left, T right);
};

struct Vec2 {
    int x;
};

impl Equatable<Vec2> {
    int equals(Vec2 left, Vec2 right) {
        return 0;
    }
}

