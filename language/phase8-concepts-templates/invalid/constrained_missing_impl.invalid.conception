=== source ===
module Main;

concept Equatable<T> {
    bool equals(T left, T right);
};

struct Vec2 {
    int x;
    int y;
};

template<T: Equatable<T>>
bool areEqual(T left, T right) {
    return equals(left, right);
}

int main() {
    Vec2 a = Vec2 { x: 1, y: 2 };
    return areEqual(a, a);
}

