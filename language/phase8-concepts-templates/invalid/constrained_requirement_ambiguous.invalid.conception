=== source ===
module Main;

concept Left<T> {
    bool test(T value);
};

concept Right<T> {
    bool test(T value);
};

struct Box { int value; };

template<T: Left<T>, U: Right<U>>
bool bad(T left, U right) {
    return test(left);
}

int main() {
    Box b = Box { value: 1 };
    if (bad(b, b)) { return 1; }
    return 0;
}

