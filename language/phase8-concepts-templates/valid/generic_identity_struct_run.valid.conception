=== source ===
module Main;

struct Vec2 {
    int x;
    int y;
};

template<T>
T identity(T value) {
    return value;
}

int main() {
    Vec2 v = identity(Vec2 {
        x: 4,
        y: 5,
    });

    return v.x;
}

=== run ===
exit_code: 4
