# name: constrained marker copy run
# phase: run
# expect: pass

=== source ===
module Main;

marker concept Copy<T>;

struct Box {
    int value;
};

impl Copy<Box>;

template<T: Copy<T>>
T pass(T value) {
    return value;
}

int main() {
    Box b = pass(Box {
        value: 7,
    });

    return b.value;
}

=== run ===
exit_code: 7
