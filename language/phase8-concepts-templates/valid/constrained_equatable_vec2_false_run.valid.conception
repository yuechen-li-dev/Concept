=== source ===
module Main;

concept Equatable<T> {
    bool equals(T left, T right);
};

struct Vec2 {
    int x;
    int y;
};

impl Equatable<Vec2> {
    bool equals(Vec2 left, Vec2 right) {
        return left.x == right.x && left.y == right.y;
    }
}

template<T: Equatable<T>>
bool areEqual(T left, T right) {
    return equals(left, right);
}

int main() {
    Vec2 a = Vec2 {
        x: 1,
        y: 2,
    };

    Vec2 b = Vec2 {
        x: 1,
        y: 3,
    };

    bool same = areEqual(a, b);

    if (same) {
        return 1;
    }

    return 0;
}

