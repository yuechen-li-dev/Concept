=== file: Main.concept ===
module Main;

import Math;
import Geometry;
import CApi;

int Sum(Geometry.Point p) {
    return Math.Add(p.x, p.y);
}

int main() {
    Geometry.Point p = Geometry.Point { x: 20, y: CApi.abs(-22) };
    return Sum(p);
}

