=== file: Geometry.concept ===
module Geometry;

[Repr(C)]
struct Point {
    int x;
    int y;
};

=== file: Main.concept ===
module Main;

import Geometry;

export "C" int SumPoint(Geometry.Point p) {
    return p.x + p.y;
}
