module Example.Tests;

int addOne(int value) {
    return value + 1;
}

[Theory]
[InlineData(1, 2)]
[InlineData(9, 10)]
void TheoryWithHelperPass(int value, int expected) {
    Expect.Equal(expected, addOne(value), "theory bodies should call helper functions while helpers are not direct test cases");
    return;
}
