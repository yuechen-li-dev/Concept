# name: phase2 closeout function call loop
# phase: run
# expect: pass

=== source ===
module Main;

int add(int a, int b) {
    return a + b;
}

int main() {
    int i = 0;
    int total = 0;

    while (i < 4) {
        total = add(total, 2);
        i = i + 1;
    }

    return total;
}

