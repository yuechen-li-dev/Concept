# name: phase2 closeout nested control flow
# phase: run
# expect: pass

=== source ===
module Main;

int main() {
    int i = 0;
    int total = 0;

    while (i < 4) {
        if (i != 2) {
            total = total + i;
        } else {
            match (i) {
                2 => total = total + 9;
                _ => total = total + 1;
            }
        }
        i = i + 1;
    }

    return total;
}

