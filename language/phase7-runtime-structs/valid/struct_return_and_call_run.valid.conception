=== source ===
module Main;

struct Vec2 {
    int x;
    int y;
};

Vec2 makeVec(int x, int y) {
    return Vec2 {
        x: x,
        y: y,
    };
}

int sum(Vec2 v) {
    return v.x + v.y;
}

int main() {
    Vec2 v = makeVec(3, 4);
    return sum(v);
}

