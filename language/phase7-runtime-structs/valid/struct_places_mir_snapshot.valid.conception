module Main;

struct Vec2 {
    int x;
    int y;
};

int main() {
    Vec2 v = Vec2 {
        x: 3,
        y: 4,
    };
    v.x = 11;
    int* px = &v.x;
    unsafe {
        return *px;
    }
}

