# name: phase20 DG2 signal yield then succeed run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

machine Child -> int { state Start { transition Middle; } state Middle { transition Done; } state Done { return 21; } }
machine YieldThenSucceed -> AutomataSignal { Child child; state Waiting { Step(child); if (!Complete(child)) { yield; } return AutomataSignal::Succeed(Reason { code: Result(child) }); } }
int main() { YieldThenSucceed m = YieldThenSucceed(); Step(m); if (Complete(m)) { return 99; } Step(m); if (Complete(m)) { return 98; } Step(m); if (!Complete(m)) { return 97; } AutomataSignal signal = Result(m); match (signal) { AutomataSignal::Succeed(reason) => return reason.code; AutomataSignal::None => return 96; AutomataSignal::Goto(target, reason) => return target.value + reason.code; AutomataSignal::Fail(reason) => return reason.code; AutomataSignal::Act(id) => return id.value; AutomataSignal::AwaitActuation(id) => return id.value; } }


=== run ===
exit_code: 21
