# name: kernel_replay_backend_shape.valid.conception
# phase: backend-c
# expect: pass

=== source ===
module Main;
struct Clock { int tick; }; struct Reason { int code; };
enum ReplayEvent { Empty, Advance(int ticks), TraceMark(Reason reason), };
struct ReplayLog { FixedBuffer<ReplayEvent, 4> events; };
struct ReplayDriver { int cursor; Clock clock; int traceMarks; };
ReplayLog replayLogEmpty(){ return ReplayLog { events:fixedBufferEmpty<ReplayEvent, 4>() }; }
int replayLogCount(ReplayLog log){ return Len(log.events); }
ReplayEvent replayLogAt(ReplayLog log, int index){ if(index >= replayLogCount(log)){ panic("DragonGod.Replay index out of range"); } return log.events[index]; }
void replayPush(mut ReplayLog& log, ReplayEvent event){ if(replayLogCount(log) >= Capacity(log.events)){ panic("DragonGod.Replay capacity exceeded"); } fixedBufferAppend(log.events, event); }
ReplayDriver replayDriverEmpty(){ return ReplayDriver { cursor:0, clock:Clock { tick:0 }, traceMarks:0 }; }
bool replayApplyNext(mut ReplayDriver& driver, ReplayLog log){ if(driver.cursor >= replayLogCount(log)){ return false; } ReplayEvent event=replayLogAt(log, driver.cursor); driver.cursor=driver.cursor+1; match(event){ ReplayEvent::Empty => { return true; } ReplayEvent::Advance(ticks) => { driver.clock.tick=driver.clock.tick+ticks; return true; } ReplayEvent::TraceMark(reason) => { driver.traceMarks=driver.traceMarks+reason.code; return true; } } }
int main(){ ReplayLog log=replayLogEmpty(); replayPush(log&, ReplayEvent::Advance(1)); ReplayDriver d=replayDriverEmpty(); if(!replayApplyNext(d&, log)){ return 1; } return d.clock.tick - 1; }

