=== source ===
module Main;

// DG8 Events v0: deterministic fixed-slot integer event stream. This is a
// kernel event substrate, not a mailbox runtime, scheduler, async system,
// dynamic event registry, or language event-bus keyword.
struct EventTypeId {
    int value;
};

struct EventId {
    int value;
};

struct EventPayloadInt {
    int value;
};

struct EventSlot {
    EventId id;
    EventTypeId type;
    EventPayloadInt payload;
    bool occupied;
};

struct EventCursor {
    int nextIndex;
};

struct EventBus {
    int nextId;
    int count;
    EventSlot slot0;
    EventSlot slot1;
    EventSlot slot2;
    EventSlot slot3;
};

EventTypeId eventType(int value) {
    return EventTypeId { value: value };
}

EventPayloadInt eventPayloadInt(int value) {
    return EventPayloadInt { value: value };
}

EventSlot eventEmptySlot() {
    return EventSlot {
        id: EventId { value: 0 },
        type: EventTypeId { value: 0 },
        payload: EventPayloadInt { value: 0 },
        occupied: false
    };
}

EventBus eventBusEmpty() {
    return EventBus {
        nextId: 1,
        count: 0,
        slot0: eventEmptySlot(),
        slot1: eventEmptySlot(),
        slot2: eventEmptySlot(),
        slot3: eventEmptySlot()
    };
}

EventCursor eventCursorStart() {
    return EventCursor { nextIndex: 0 };
}

EventCursor eventTailCursor(EventBus bus) {
    return EventCursor { nextIndex: bus.count };
}

void eventFillSlot(mut EventSlot& slot, EventId id, EventTypeId type, EventPayloadInt payload) {
    slot.id = id;
    slot.type = type;
    slot.payload = payload;
    slot.occupied = true;
}

EventId eventPush(mut EventBus& bus, EventTypeId type, EventPayloadInt payload) {
    EventId id = EventId { value: bus.nextId };
    bus.nextId = bus.nextId + 1;

    if (!bus.slot0.occupied) { eventFillSlot(bus.slot0&, id, type, payload); bus.count = bus.count + 1; return id; }
    if (!bus.slot1.occupied) { eventFillSlot(bus.slot1&, id, type, payload); bus.count = bus.count + 1; return id; }
    if (!bus.slot2.occupied) { eventFillSlot(bus.slot2&, id, type, payload); bus.count = bus.count + 1; return id; }
    if (!bus.slot3.occupied) { eventFillSlot(bus.slot3&, id, type, payload); bus.count = bus.count + 1; return id; }
    panic("DragonGod.Events capacity exceeded");
}

bool eventSlotMatches(EventSlot slot, EventTypeId type) {
    return slot.occupied && slot.type.value == type.value;
}

int eventReadNextInt(EventBus bus, mut EventCursor& cursor, EventTypeId type, int fallback) {
    if (cursor.nextIndex <= 0) {
        if (eventSlotMatches(bus.slot0, type)) { cursor.nextIndex = 1; return bus.slot0.payload.value; }
    }
    if (cursor.nextIndex <= 1) {
        if (eventSlotMatches(bus.slot1, type)) { cursor.nextIndex = 2; return bus.slot1.payload.value; }
    }
    if (cursor.nextIndex <= 2) {
        if (eventSlotMatches(bus.slot2, type)) { cursor.nextIndex = 3; return bus.slot2.payload.value; }
    }
    if (cursor.nextIndex <= 3) {
        if (eventSlotMatches(bus.slot3, type)) { cursor.nextIndex = 4; return bus.slot3.payload.value; }
    }
    cursor.nextIndex = bus.count;
    return fallback;
}

// MemoryKey<T> is deferred until generic/type-erased Memory is ready.
// MemoryKeyInt is the DG3 scaffold for integer memory values.
struct MemoryKeyInt {
    int id;
};
// DG3 Memory v0: fixed four-slot integer store. No heap, hash map, TTL,
// changed-key set, persistence, or type-erased payload storage yet.
struct MemorySlot {
    int key;
    int value;
    bool occupied;
};

struct Memory {
    int revision;
    MemorySlot slot0;
    MemorySlot slot1;
    MemorySlot slot2;
    MemorySlot slot3;
};

MemorySlot memoryEmptySlot() {
    return MemorySlot { key: 0, value: 0, occupied: false };
}

Memory memoryEmpty() {
    return Memory {
        revision: 0,
        slot0: memoryEmptySlot(),
        slot1: memoryEmptySlot(),
        slot2: memoryEmptySlot(),
        slot3: memoryEmptySlot()
    };
}

void memoryWrite(mut Memory& memory, MemoryKeyInt key, int value) {
    if (memory.slot0.occupied && memory.slot0.key == key.id) {
        memory.slot0.value = value;
        memory.revision = memory.revision + 1;
        return;
    }
    if (memory.slot1.occupied && memory.slot1.key == key.id) {
        memory.slot1.value = value;
        memory.revision = memory.revision + 1;
        return;
    }
    if (memory.slot2.occupied && memory.slot2.key == key.id) {
        memory.slot2.value = value;
        memory.revision = memory.revision + 1;
        return;
    }
    if (memory.slot3.occupied && memory.slot3.key == key.id) {
        memory.slot3.value = value;
        memory.revision = memory.revision + 1;
        return;
    }

    if (!memory.slot0.occupied) {
        memory.slot0.key = key.id;
        memory.slot0.value = value;
        memory.slot0.occupied = true;
        memory.revision = memory.revision + 1;
        return;
    }
    if (!memory.slot1.occupied) {
        memory.slot1.key = key.id;
        memory.slot1.value = value;
        memory.slot1.occupied = true;
        memory.revision = memory.revision + 1;
        return;
    }
    if (!memory.slot2.occupied) {
        memory.slot2.key = key.id;
        memory.slot2.value = value;
        memory.slot2.occupied = true;
        memory.revision = memory.revision + 1;
        return;
    }
    if (!memory.slot3.occupied) {
        memory.slot3.key = key.id;
        memory.slot3.value = value;
        memory.slot3.occupied = true;
        memory.revision = memory.revision + 1;
        return;
    }
}

int memoryRead(Memory memory, MemoryKeyInt key, int fallback) {
    if (memory.slot0.occupied && memory.slot0.key == key.id) { return memory.slot0.value; }
    if (memory.slot1.occupied && memory.slot1.key == key.id) { return memory.slot1.value; }
    if (memory.slot2.occupied && memory.slot2.key == key.id) { return memory.slot2.value; }
    if (memory.slot3.occupied && memory.slot3.key == key.id) { return memory.slot3.value; }
    return fallback;
}

bool memoryHas(Memory memory, MemoryKeyInt key) {
    if (memory.slot0.occupied && memory.slot0.key == key.id) { return true; }
    if (memory.slot1.occupied && memory.slot1.key == key.id) { return true; }
    if (memory.slot2.occupied && memory.slot2.key == key.id) { return true; }
    if (memory.slot3.occupied && memory.slot3.key == key.id) { return true; }
    return false;
}

int memoryRevision(Memory memory) {
    return memory.revision;
}
int main() { EventBus bus = eventBusEmpty(); EventTypeId threat = eventType(1); eventPush(bus&, threat, eventPayloadInt(80)); EventCursor cursor = eventCursorStart(); Memory memory = memoryEmpty(); memoryWrite(memory&, MemoryKeyInt { id: 7 }, eventReadNextInt(bus, cursor&, threat, 0)); return memoryRead(memory, MemoryKeyInt { id: 7 }, 0) - 80; }

