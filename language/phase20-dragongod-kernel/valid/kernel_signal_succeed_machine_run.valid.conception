# name: phase20 DG2 signal succeed machine run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

machine SucceedNow -> AutomataSignal {
    state Start {
        return AutomataSignal::Succeed(Reason { code: 7 });
    }
}

int main() {
    SucceedNow m = SucceedNow();
    Step(m);
    if (!Complete(m)) { return 98; }
    AutomataSignal signal = Result(m);
    match (signal) {
        AutomataSignal::Succeed(reason) => return reason.code;
        AutomataSignal::None => return 99;
        AutomataSignal::Goto(target, reason) => return target.value + reason.code;
        AutomataSignal::Fail(reason) => return reason.code;
        AutomataSignal::Act(id) => return id.value;
        AutomataSignal::AwaitActuation(id) => return id.value;
    }
}


=== run ===
exit_code: 7
