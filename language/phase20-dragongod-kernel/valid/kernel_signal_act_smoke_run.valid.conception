# name: phase20 DG2 signal act smoke run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

machine ActNow -> AutomataSignal { state Start { return AutomataSignal::Act(ActuationId { value: 31 }); } }
int main() { ActNow m = ActNow(); Step(m); AutomataSignal signal = Result(m); match (signal) { AutomataSignal::Act(id) => return id.value; AutomataSignal::AwaitActuation(id) => return id.value; AutomataSignal::None => return 99; AutomataSignal::Goto(target, reason) => return target.value + reason.code; AutomataSignal::Succeed(reason) => return reason.code; AutomataSignal::Fail(reason) => return reason.code; } }


=== run ===
exit_code: 31
