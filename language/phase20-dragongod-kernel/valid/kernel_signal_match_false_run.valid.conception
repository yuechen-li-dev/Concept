# name: phase20 DG2 signal transition match false run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

machine GateSignal(bool ok) -> AutomataSignal { state Start { transition match (ok) { true => Good; false => Bad; }; } state Good { return AutomataSignal::Succeed(Reason { code: 1 }); } state Bad { return AutomataSignal::Fail(Reason { code: 2 }); } }
int main() { GateSignal m = GateSignal(false); Step(m); Step(m); AutomataSignal signal = Result(m); match (signal) { AutomataSignal::Succeed(reason) => return reason.code; AutomataSignal::Fail(reason) => return reason.code; AutomataSignal::None => return 99; AutomataSignal::Goto(target, reason) => return target.value + reason.code; AutomataSignal::Act(id) => return id.value; AutomataSignal::AwaitActuation(id) => return id.value; } }


=== run ===
exit_code: 2
