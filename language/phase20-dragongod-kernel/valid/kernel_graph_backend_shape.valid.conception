# name: kernel_graph_backend_shape.valid.conception
# phase: backend-c
# expect: pass

=== source ===
module Main;
struct StateId { int value; }; struct Reason { int code; };
struct AutomatonNodeId { int value; };
enum AutomatonNodeKind { Empty, StaticState, MachineKind, External, };
struct AutomatonNode { AutomatonNodeId id; StateId state; AutomatonNodeKind kind; Reason reason; bool occupied; };
struct AutomatonGraph { int nextId; AutomatonNodeId root; bool hasRoot; FixedBuffer<AutomatonNode, 4> nodes; };
AutomatonNodeId automatonNodeId(int value) { return AutomatonNodeId { value: value }; }
AutomatonNode automatonNode(AutomatonNodeId id, StateId state, AutomatonNodeKind kind, Reason reason) { return AutomatonNode { id: id, state: state, kind: kind, reason: reason, occupied: true }; }
AutomatonGraph automatonGraphEmpty() { return AutomatonGraph { nextId: 1, root: automatonNodeId(0), hasRoot: false, nodes: fixedBufferEmpty<AutomatonNode, 4>() }; }
int automatonGraphCount(AutomatonGraph graph) { return Len(graph.nodes); }
void automatonGraphStoreNode(mut AutomatonGraph& graph, AutomatonNode node) { if (automatonGraphCount(graph) >= Capacity(graph.nodes)) { panic("DragonGod.Graph capacity exceeded"); } fixedBufferAppend(graph.nodes, node); }
AutomatonNodeId automatonGraphAddNode(mut AutomatonGraph& graph, StateId state, AutomatonNodeKind kind, Reason reason) { AutomatonNodeId id = automatonNodeId(graph.nextId); graph.nextId = graph.nextId + 1; automatonGraphStoreNode(graph&, automatonNode(id, state, kind, reason)); return id; }
bool automatonGraphNodeMatches(AutomatonNode node, AutomatonNodeId id) { return node.occupied && node.id.value == id.value; }
bool automatonGraphHasNode(AutomatonGraph graph, AutomatonNodeId id) { if (Len(graph.nodes) > 0 && automatonGraphNodeMatches(graph.nodes[0], id)) { return true; } if (Len(graph.nodes) > 1 && automatonGraphNodeMatches(graph.nodes[1], id)) { return true; } return false; }
AutomatonNode automatonGraphFindNode(AutomatonGraph graph, AutomatonNodeId id) { if (Len(graph.nodes) > 0 && automatonGraphNodeMatches(graph.nodes[0], id)) { return graph.nodes[0]; } if (Len(graph.nodes) > 1 && automatonGraphNodeMatches(graph.nodes[1], id)) { return graph.nodes[1]; } panic("DragonGod.Graph node not found"); }
void automatonGraphSetRoot(mut AutomatonGraph& graph, AutomatonNodeId id) { if (!automatonGraphHasNode(graph, id)) { panic("DragonGod.Graph root node not found"); } graph.root = id; graph.hasRoot = true; }
AutomatonNode automatonGraphRootNode(AutomatonGraph graph) { if (!graph.hasRoot) { panic("DragonGod.Graph root not set"); } return automatonGraphFindNode(graph, graph.root); }
int main() { AutomatonGraph g = automatonGraphEmpty(); AutomatonNodeId id = automatonGraphAddNode(g&, StateId { value: 12 }, AutomatonNodeKind::StaticState, Reason { code: 1 }); automatonGraphSetRoot(g&, id); return automatonGraphRootNode(g).state.value - 12; }

