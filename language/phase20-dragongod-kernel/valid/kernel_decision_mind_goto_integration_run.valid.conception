=== source ===
module Main;

struct StateId { int value; };
struct DecisionSlotId { int value; };
struct Reason { int code; };
struct DecisionSlot { DecisionSlotId id; };
struct DecisionPolicy { int hysteresisDelta; int minCommitTicks; int tieEpsilon; };
struct DecisionMemory { StateId currentOption; int currentScore; int lastSwitchTick; bool hasCurrent; };
struct UtilityOption { StateId target; int score; bool enabled; };
DecisionPolicy decisionPolicyDefault() { return DecisionPolicy { hysteresisDelta: 0, minCommitTicks: 0, tieEpsilon: 0 }; }
DecisionMemory decisionMemoryEmpty() { return DecisionMemory { currentOption: StateId { value: 0 }, currentScore: 0, lastSwitchTick: 0, hasCurrent: false }; }
UtilityOption utilityOption(StateId target, int score, bool enabled) { return UtilityOption { target: target, score: score, enabled: enabled }; }
int decisionAbsDiff(int left, int right) { if (left >= right) { return left - right; } return right - left; }
UtilityOption decisionBestOption4(UtilityOption option0, UtilityOption option1, UtilityOption option2, UtilityOption option3, StateId fallback) { UtilityOption best = UtilityOption { target: fallback, score: 0, enabled: false }; if (option0.enabled) { best = option0; } if (option1.enabled && (!best.enabled || option1.score > best.score)) { best = option1; } if (option2.enabled && (!best.enabled || option2.score > best.score)) { best = option2; } if (option3.enabled && (!best.enabled || option3.score > best.score)) { best = option3; } return best; }
StateId decisionChoose4(mut DecisionMemory& memory, DecisionPolicy policy, int nowTick, UtilityOption option0, UtilityOption option1, UtilityOption option2, UtilityOption option3, StateId fallback) { UtilityOption best = decisionBestOption4(option0, option1, option2, option3, fallback); if (!best.enabled) { return fallback; } if (!memory.hasCurrent) { memory.currentOption = best.target; memory.currentScore = best.score; memory.lastSwitchTick = nowTick; memory.hasCurrent = true; return best.target; } if (best.target.value == memory.currentOption.value) { memory.currentScore = best.score; return memory.currentOption; } if (nowTick - memory.lastSwitchTick < policy.minCommitTicks) { return memory.currentOption; } if (best.score <= memory.currentScore + policy.hysteresisDelta) { return memory.currentOption; } if (decisionAbsDiff(best.score, memory.currentScore) <= policy.tieEpsilon) { return memory.currentOption; } memory.currentOption = best.target; memory.currentScore = best.score; memory.lastSwitchTick = nowTick; memory.hasCurrent = true; return best.target; }
enum AutomataSignal { None, Goto(StateId target, Reason reason), Succeed(Reason reason), Fail(Reason reason), Act(int id), AwaitActuation(int id), Push(StateId target, Reason reason), Pop(Reason reason), }; enum MindStatus { Idle, Running, Succeeded, Failed, WaitingActuation, }; struct AutomataFrame { StateId state; Reason reason; }; struct AutomataStack { int depth; AutomataFrame frame0; }; AutomataFrame automataFrame(StateId state, Reason reason) { return AutomataFrame { state: state, reason: reason }; } AutomataStack automataStackEmpty() { return AutomataStack { depth: 0, frame0: automataFrame(StateId { value: 0 }, Reason { code: 0 }) }; } bool automataStackIsEmpty(AutomataStack stack) { return stack.depth == 0; } void automataStackPush(mut AutomataStack& stack, StateId state, Reason reason) { stack.frame0 = automataFrame(state, reason); stack.depth = 1; } void automataStackReplaceTop(mut AutomataStack& stack, StateId state, Reason reason) { stack.frame0 = automataFrame(state, reason); } AutomataFrame automataStackTop(AutomataStack stack) { return stack.frame0; } struct Mind { int active; MindStatus status; AutomataSignal lastSignal; Reason lastReason; AutomataStack stack; }; Mind mindEmpty() { return Mind { active: 0, status: MindStatus::Idle, lastSignal: AutomataSignal::None, lastReason: Reason { code: 0 }, stack: automataStackEmpty() }; } void mindRecordSignal(mut Mind& mind, AutomataSignal signal) { mind.lastSignal = signal; match (signal) { AutomataSignal::Goto(target, reason) => { if (automataStackIsEmpty(mind.stack)) { automataStackPush(mind.stack&, target, reason); } else { automataStackReplaceTop(mind.stack&, target, reason); } mind.status = MindStatus::Running; mind.lastReason = reason; return; } AutomataSignal::Succeed(reason) => { mind.status = MindStatus::Succeeded; mind.lastReason = reason; return; } AutomataSignal::Fail(reason) => { mind.status = MindStatus::Failed; mind.lastReason = reason; return; } AutomataSignal::Act(id) => { mind.status = MindStatus::Running; return; } AutomataSignal::AwaitActuation(id) => { mind.status = MindStatus::WaitingActuation; return; } AutomataSignal::Push(target, reason) => { automataStackPush(mind.stack&, target, reason); mind.status = MindStatus::Running; mind.lastReason = reason; return; } AutomataSignal::Pop(reason) => { mind.status = MindStatus::Idle; mind.lastReason = reason; return; } AutomataSignal::None => { return; } } } StateId mindCurrentState(Mind mind) { return automataStackTop(mind.stack).state; }

int main() { DecisionMemory d = decisionMemoryEmpty(); StateId chosen = decisionChoose4(d&, decisionPolicyDefault(), 0, utilityOption(StateId { value: 42 }, 100, true), utilityOption(StateId { value: 1 }, 0, true), utilityOption(StateId { value: 2 }, 0, false), utilityOption(StateId { value: 3 }, 0, false), StateId { value: 99 }); Mind mind = mindEmpty(); mindRecordSignal(mind&, AutomataSignal::Goto(chosen, Reason { code: 6 })); return mindCurrentState(mind).value; }

