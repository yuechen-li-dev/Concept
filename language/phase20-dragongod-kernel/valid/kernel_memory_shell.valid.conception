module Main;

struct Memory {
    int revision;
};

struct MemoryKeyInt {
    int id;
};

int memoryRevision(Memory memory) {
    return memory.revision;
}

int main() {
    Memory memory = Memory { revision: 40 };
    MemoryKeyInt key = MemoryKeyInt { id: 2 };
    return memoryRevision(memory) + key.id;
}

