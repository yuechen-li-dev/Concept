=== source ===
module Main;
struct Clock { int tick; }; struct AgentId { int value; }; struct StateId { int value; }; struct ActuationId { int value; }; struct Reason { int code; }; struct MemoryKeyInt { int id; };
struct MemorySlot { int key; int value; bool occupied; }; struct Memory { int revision; MemorySlot slot0; MemorySlot slot1; MemorySlot slot2; MemorySlot slot3; };
MemorySlot memoryEmptySlot(){ return MemorySlot { key:0, value:0, occupied:false }; } Memory memoryEmpty(){ return Memory { revision:0, slot0:memoryEmptySlot(), slot1:memoryEmptySlot(), slot2:memoryEmptySlot(), slot3:memoryEmptySlot() }; }
void memoryWrite(mut Memory& memory, MemoryKeyInt key, int value){ if(!memory.slot0.occupied){ memory.slot0.key=key.id; memory.slot0.value=value; memory.slot0.occupied=true; memory.revision=memory.revision+1; return; } if(memory.slot0.key==key.id){ memory.slot0.value=value; memory.revision=memory.revision+1; return; } }
int memoryRead(Memory memory, MemoryKeyInt key, int fallback){ if(memory.slot0.occupied && memory.slot0.key == key.id){ return memory.slot0.value; } return fallback; }
struct EventTypeId { int value; }; struct EventId { int value; }; struct EventPayloadInt { int value; }; struct EventSlot { EventId id; EventTypeId type; EventPayloadInt payload; bool occupied; }; struct EventCursor { int nextIndex; }; struct EventBus { int nextId; int count; EventSlot slot0; EventSlot slot1; EventSlot slot2; EventSlot slot3; };
EventTypeId eventType(int value){ return EventTypeId { value:value }; } EventPayloadInt eventPayloadInt(int value){ return EventPayloadInt { value:value }; } EventSlot eventEmptySlot(){ return EventSlot { id:EventId { value:0 }, type:EventTypeId { value:0 }, payload:EventPayloadInt { value:0 }, occupied:false }; } EventBus eventBusEmpty(){ return EventBus { nextId:1, count:0, slot0:eventEmptySlot(), slot1:eventEmptySlot(), slot2:eventEmptySlot(), slot3:eventEmptySlot() }; } EventCursor eventCursorStart(){ return EventCursor { nextIndex:0 }; }
EventId eventPush(mut EventBus& bus, EventTypeId type, EventPayloadInt payload){ EventId id=EventId { value:bus.nextId }; bus.nextId=bus.nextId+1; bus.slot0=EventSlot { id:id, type:type, payload:payload, occupied:true }; bus.count=bus.count+1; return id; }
int eventReadNextInt(EventBus bus, mut EventCursor& cursor, EventTypeId type, int fallback){ if(cursor.nextIndex<=0 && bus.slot0.occupied && bus.slot0.type.value==type.value){ cursor.nextIndex=1; return bus.slot0.payload.value; } return fallback; }
enum ActuationStatus { Empty, Pending, Completed, Failed, }; struct ActuationSlot { ActuationId id; ActuationStatus status; Reason reason; bool occupied; }; struct ActuatorHost { int nextId; ActuationSlot slot0; ActuationSlot slot1; ActuationSlot slot2; ActuationSlot slot3; }; struct ActuationDecision { bool allowed; Reason reason; }; struct ActuationDispatchResult { ActuationId id; bool accepted; bool completed; bool ok; Reason reason; };
ActuationSlot actuationEmptySlot(){ return ActuationSlot { id:ActuationId { value:0 }, status:ActuationStatus::Empty, reason:Reason { code:0 }, occupied:false }; } ActuatorHost actuatorHostEmpty(){ return ActuatorHost { nextId:1, slot0:actuationEmptySlot(), slot1:actuationEmptySlot(), slot2:actuationEmptySlot(), slot3:actuationEmptySlot() }; } ActuationDecision actuationAllow(){ return ActuationDecision { allowed:true, reason:Reason { code:0 } }; } ActuationDispatchResult actuatorDispatch(mut ActuatorHost& host, ActuationDecision d){ ActuationId id=ActuationId { value:host.nextId }; host.nextId=host.nextId+1; host.slot0=ActuationSlot { id:id, status:ActuationStatus::Pending, reason:d.reason, occupied:true }; return ActuationDispatchResult { id:id, accepted:true, completed:false, ok:true, reason:d.reason }; }
void actuatorComplete(mut ActuatorHost& host, ActuationId id, Reason reason){ if(host.slot0.occupied && host.slot0.id.value==id.value){ host.slot0.status=ActuationStatus::Completed; host.slot0.reason=reason; return; } } void actuatorFail(mut ActuatorHost& host, ActuationId id, Reason reason){ if(host.slot0.occupied && host.slot0.id.value==id.value){ host.slot0.status=ActuationStatus::Failed; host.slot0.reason=reason; return; } } ActuationStatus actuatorStatus(ActuatorHost host, ActuationId id){ if(host.slot0.occupied && host.slot0.id.value==id.value){ return host.slot0.status; } return ActuationStatus::Empty; }
enum TraceEventKind { Empty, Enter, }; struct TraceEvent { TraceEventKind kind; StateId from; StateId to; Reason reason; int tick; bool occupied; }; struct TraceRecorder { int count; TraceEvent event0; TraceEvent event1; TraceEvent event2; TraceEvent event3; }; TraceEvent traceEmptyEvent(){ return TraceEvent { kind:TraceEventKind::Empty, from:StateId { value:0 }, to:StateId { value:0 }, reason:Reason { code:0 }, tick:0, occupied:false }; } TraceRecorder traceRecorderEmpty(){ return TraceRecorder { count:0, event0:traceEmptyEvent(), event1:traceEmptyEvent(), event2:traceEmptyEvent(), event3:traceEmptyEvent() }; } void traceEnter(mut TraceRecorder& r, StateId s, int tick, Reason reason){ r.event0=TraceEvent { kind:TraceEventKind::Enter, from:s, to:s, reason:reason, tick:tick, occupied:true }; r.count=r.count+1; }
struct Mind { int active; }; struct Agent { AgentId id; Memory memory; Mind mind; }; struct World { Clock clock; Memory memory; };
enum ReplayEvent { Empty, Advance(int ticks), WorldMemoryWriteInt(MemoryKeyInt key, int value), AgentMemoryWriteInt(MemoryKeyInt key, int value), EventPushInt(EventTypeId eventType, int value), ActuationComplete(ActuationId id, Reason reason), ActuationFail(ActuationId id, Reason reason), TraceMark(Reason reason), RngSeed(int seed), };
struct ReplayLog { int count; ReplayEvent event0; ReplayEvent event1; ReplayEvent event2; ReplayEvent event3; }; struct ReplayDriver { int cursor; World world; Agent agent; EventBus events; ActuatorHost actuator; TraceRecorder trace; int rngSeed; };
ReplayEvent replayEmptyEvent(){ return ReplayEvent::Empty; } ReplayLog replayLogEmpty(){ return ReplayLog { count:0, event0:replayEmptyEvent(), event1:replayEmptyEvent(), event2:replayEmptyEvent(), event3:replayEmptyEvent() }; } int replayLogCount(ReplayLog log){ return log.count; } ReplayEvent replayLogAt(ReplayLog log, int index){ if(index==0){ return log.event0; } if(index==1){ return log.event1; } if(index==2){ return log.event2; } if(index==3){ return log.event3; } panic("DragonGod.Replay index out of range"); }
void replayPush(mut ReplayLog& log, ReplayEvent event){ if(log.count==0){ log.event0=event; log.count=1; return; } if(log.count==1){ log.event1=event; log.count=2; return; } if(log.count==2){ log.event2=event; log.count=3; return; } if(log.count==3){ log.event3=event; log.count=4; return; } panic("DragonGod.Replay capacity exceeded"); }
ReplayDriver replayDriverEmpty(){ return ReplayDriver { cursor:0, world:World { clock:Clock { tick:0 }, memory:memoryEmpty() }, agent:Agent { id:AgentId { value:0 }, memory:memoryEmpty(), mind:Mind { active:0 } }, events:eventBusEmpty(), actuator:actuatorHostEmpty(), trace:traceRecorderEmpty(), rngSeed:0 }; }
bool replayApplyNext(mut ReplayDriver& driver, ReplayLog log){ if(driver.cursor >= replayLogCount(log)){ return false; } ReplayEvent event=replayLogAt(log, driver.cursor); driver.cursor=driver.cursor+1; match(event){ ReplayEvent::Empty => { return true; } ReplayEvent::Advance(ticks) => { driver.world.clock.tick=driver.world.clock.tick+ticks; return true; } ReplayEvent::WorldMemoryWriteInt(key,value) => { memoryWrite(driver.world.memory&, key, value); return true; } ReplayEvent::AgentMemoryWriteInt(key,value) => { memoryWrite(driver.agent.memory&, key, value); return true; } ReplayEvent::EventPushInt(eventType,value) => { discard eventPush(driver.events&, eventType, eventPayloadInt(value)); return true; } ReplayEvent::ActuationComplete(id,reason) => { actuatorComplete(driver.actuator&, id, reason); return true; } ReplayEvent::ActuationFail(id,reason) => { actuatorFail(driver.actuator&, id, reason); return true; } ReplayEvent::TraceMark(reason) => { traceEnter(driver.trace&, StateId { value:reason.code }, driver.world.clock.tick, reason); return true; } ReplayEvent::RngSeed(seed) => { driver.rngSeed=seed; return true; } } }
int replayApplyAll(mut ReplayDriver& driver, ReplayLog log){ int applied=0; if(replayApplyNext(driver&, log)){ applied=applied+1; } if(replayApplyNext(driver&, log)){ applied=applied+1; } if(replayApplyNext(driver&, log)){ applied=applied+1; } if(replayApplyNext(driver&, log)){ applied=applied+1; } return applied; }
int main(){ ReplayLog log=replayLogEmpty(); replayPush(log&, ReplayEvent::EventPushInt(eventType(1), 42)); ReplayDriver d=replayDriverEmpty(); if(replayApplyAll(d&, log) != 1){ return 1; } EventCursor c=eventCursorStart(); return eventReadNextInt(d.events, c&, eventType(1), 0) - 42; }

