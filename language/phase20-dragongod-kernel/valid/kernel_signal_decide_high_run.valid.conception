# name: phase20 DG2 signal transition decide high run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

machine DecideSignal(bool high) -> AutomataSignal { state Start { transition decide { High when high score 100; Low score 1; }; } state High { return AutomataSignal::Succeed(Reason { code: 100 }); } state Low { return AutomataSignal::Succeed(Reason { code: 1 }); } }
int main() { DecideSignal m = DecideSignal(true); Step(m); Step(m); AutomataSignal signal = Result(m); match (signal) { AutomataSignal::Succeed(reason) => return reason.code; AutomataSignal::None => return 99; AutomataSignal::Goto(target, reason) => return target.value + reason.code; AutomataSignal::Fail(reason) => return reason.code; AutomataSignal::Act(id) => return id.value; AutomataSignal::AwaitActuation(id) => return id.value; } }


=== run ===
exit_code: 100
