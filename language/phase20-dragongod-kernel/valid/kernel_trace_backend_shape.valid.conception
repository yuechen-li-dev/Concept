# name: kernel_trace_backend_shape.valid.conception
# phase: backend-c
# expect: pass

=== source ===
module Main;
struct StateId { int value; }; struct ActuationId { int value; }; struct Reason { int code; };
enum AutomataSignal { None, Succeed(Reason reason), };
enum TraceEventKind { Empty, Enter, Signal, };
struct TraceEvent { TraceEventKind kind; StateId from; StateId to; Reason reason; int tick; AutomataSignal signal; bool occupied; };
struct TraceRecorder { FixedBuffer<TraceEvent, 4> events; };
TraceRecorder traceRecorderEmpty() { return TraceRecorder { events: fixedBufferEmpty<TraceEvent, 4>() }; }
int traceCount(TraceRecorder recorder) { return Len(recorder.events); }
TraceEvent traceAt(TraceRecorder recorder, int index) { if (index >= traceCount(recorder)) { panic("DragonGod.Trace index out of range"); } return recorder.events[index]; }
void traceAppend(mut TraceRecorder& recorder, TraceEvent event) { if (traceCount(recorder) >= Capacity(recorder.events)) { panic("DragonGod.Trace capacity exceeded"); } fixedBufferAppend(recorder.events, event); }
void traceEnter(mut TraceRecorder& recorder, StateId state, int tick, Reason reason) { traceAppend(recorder&, TraceEvent { kind: TraceEventKind::Enter, from: state, to: state, reason: reason, tick: tick, signal: AutomataSignal::None, occupied: true }); }
void traceSignal(mut TraceRecorder& recorder, AutomataSignal signal, int tick) { traceAppend(recorder&, TraceEvent { kind: TraceEventKind::Signal, from: StateId { value: 0 }, to: StateId { value: 0 }, reason: Reason { code: 0 }, tick: tick, signal: signal, occupied: true }); }
int traceSignalReasonCode(TraceEvent event) { match (event.signal) { AutomataSignal::Succeed(reason) => { return reason.code; } AutomataSignal::None => { return 0; } } }
int main() { TraceRecorder r = traceRecorderEmpty(); traceEnter(r&, StateId { value: 1 }, 0, Reason { code: 7 }); traceSignal(r&, AutomataSignal::Succeed(Reason { code: 42 }), 1); if (traceCount(r) != 2) { return 1; } return traceSignalReasonCode(traceAt(r, 1)) - 42; }

