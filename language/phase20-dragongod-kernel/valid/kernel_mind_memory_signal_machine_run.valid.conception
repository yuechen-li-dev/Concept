# name: kernel_mind_memory_signal_machine_run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };
enum AutomataSignal { None, Goto(StateId target, Reason reason), Succeed(Reason reason), Fail(Reason reason), Act(ActuationId id), AwaitActuation(ActuationId id), };
enum MindStatus { Idle, Running, Succeeded, Failed, WaitingActuation, };
struct Mind { int active; MindStatus status; AutomataSignal lastSignal; Reason lastReason; };
Mind mindEmpty() { return Mind { active: 0, status: MindStatus::Idle, lastSignal: AutomataSignal::None, lastReason: Reason { code: 0 } }; }
void mindRecordSignal(mut Mind& mind, AutomataSignal signal) { mind.lastSignal = signal; match (signal) { AutomataSignal::Succeed(reason) => { mind.status = MindStatus::Succeeded; mind.lastReason = reason; return; } AutomataSignal::Fail(reason) => { mind.status = MindStatus::Failed; mind.lastReason = reason; return; } AutomataSignal::AwaitActuation(id) => { mind.status = MindStatus::WaitingActuation; return; } AutomataSignal::Act(id) => { mind.status = MindStatus::Running; return; } AutomataSignal::Goto(target, reason) => { mind.status = MindStatus::Running; mind.lastReason = reason; return; } AutomataSignal::None => { return; } } }
bool mindIsDone(Mind mind) { return mind.status == MindStatus::Succeeded || mind.status == MindStatus::Failed; }
int mindLastReasonCode(Mind mind) { return mind.lastReason.code; }

struct MemoryKeyInt { int id; };
struct MemorySlot { int key; int value; bool occupied; };
struct Memory { int revision; MemorySlot slot0; MemorySlot slot1; MemorySlot slot2; MemorySlot slot3; };
MemorySlot memoryEmptySlot() { return MemorySlot { key: 0, value: 0, occupied: false }; }
Memory memoryEmpty() { return Memory { revision: 0, slot0: memoryEmptySlot(), slot1: memoryEmptySlot(), slot2: memoryEmptySlot(), slot3: memoryEmptySlot() }; }
void memoryWrite(mut Memory& memory, MemoryKeyInt key, int value) { if (!memory.slot0.occupied) { memory.slot0.key = key.id; memory.slot0.value = value; memory.slot0.occupied = true; memory.revision = memory.revision + 1; return; } }
int memoryRead(Memory memory, MemoryKeyInt key, int fallback) { if (memory.slot0.occupied && memory.slot0.key == key.id) { return memory.slot0.value; } return fallback; }
machine MemorySignal(Memory memory, MemoryKeyInt key) -> AutomataSignal { state Start { int value = memoryRead(memory, key, 0); transition decide { High when value > 50 score 100; Low score 1; }; } state High { return AutomataSignal::Succeed(Reason { code: 100 }); } state Low { return AutomataSignal::Fail(Reason { code: 1 }); } }
int main() { Memory memory = memoryEmpty(); MemoryKeyInt key = MemoryKeyInt { id: 1 }; memoryWrite(memory&, key, 77); Mind mind = mindEmpty(); MemorySignal machine = MemorySignal(memory, key); Step(machine); if (Complete(machine)) { mindRecordSignal(mind&, Result(machine)); } return mindLastReasonCode(mind); }

=== run ===
exit_code: 100
