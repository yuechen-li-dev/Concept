=== source ===
module Main;

struct AgentId {
    int value;
};

struct StateId {
    int value;
};

struct ActuationId {
    int value;
};

struct DecisionSlotId {
    int value;
};

struct Clock {
    int tick;
};

struct Reason {
    int code;
};

int main() {
    AgentId agent = AgentId { value: 10 };
    StateId state = StateId { value: 20 };
    ActuationId act = ActuationId { value: 5 };
    DecisionSlotId slot = DecisionSlotId { value: 3 };
    Clock clock = Clock { tick: 2 };
    Reason reason = Reason { code: 2 };
    return agent.value + state.value + act.value + slot.value + clock.tick + reason.code;
}

