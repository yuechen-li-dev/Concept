module Main;
struct Clock { int tick; }; struct AgentId { int value; }; struct StateId { int value; }; struct ActuationId { int value; }; struct Reason { int code; }; struct MemoryKeyInt { int id; };
struct MemorySlot { int key; int value; bool occupied; }; struct Memory { int revision; MemorySlot slot0; MemorySlot slot1; MemorySlot slot2; MemorySlot slot3; };
MemorySlot memoryEmptySlot(){ return MemorySlot { key:0, value:0, occupied:false }; } Memory memoryEmpty(){ return Memory { revision:0, slot0:memoryEmptySlot(), slot1:memoryEmptySlot(), slot2:memoryEmptySlot(), slot3:memoryEmptySlot() }; }
void memoryWrite(mut Memory& m, MemoryKeyInt k, int v){ if(m.slot0.occupied && m.slot0.key==k.id){ m.slot0.value=v; m.revision=m.revision+1; return; } if(!m.slot0.occupied){ m.slot0.key=k.id; m.slot0.value=v; m.slot0.occupied=true; m.revision=m.revision+1; return; } }
int memoryRead(Memory m, MemoryKeyInt k, int f){ if(m.slot0.occupied && m.slot0.key==k.id){ return m.slot0.value; } return f; }
struct EventTypeId { int value; }; struct EventId { int value; }; struct EventPayloadInt { int value; }; struct EventSlot { EventId id; EventTypeId type; EventPayloadInt payload; bool occupied; }; struct EventCursor { int nextIndex; }; struct EventBus { int nextId; int count; EventSlot slot0; EventSlot slot1; EventSlot slot2; EventSlot slot3; };
EventTypeId eventType(int v){ return EventTypeId { value:v }; } EventPayloadInt eventPayloadInt(int v){ return EventPayloadInt { value:v }; } EventSlot eventEmptySlot(){ return EventSlot { id:EventId { value:0 }, type:EventTypeId { value:0 }, payload:EventPayloadInt { value:0 }, occupied:false }; } EventBus eventBusEmpty(){ return EventBus { nextId:1, count:0, slot0:eventEmptySlot(), slot1:eventEmptySlot(), slot2:eventEmptySlot(), slot3:eventEmptySlot() }; } EventCursor eventCursorStart(){ return EventCursor { nextIndex:0 }; }
EventId eventPush(mut EventBus& b, EventTypeId t, EventPayloadInt p){ EventId id=EventId { value:b.nextId }; b.nextId=b.nextId+1; if(!b.slot0.occupied){ b.slot0=EventSlot { id:id, type:t, payload:p, occupied:true }; b.count=b.count+1; return id; } if(!b.slot1.occupied){ b.slot1=EventSlot { id:id, type:t, payload:p, occupied:true }; b.count=b.count+1; return id; } return id; }
int eventReadNextInt(EventBus b, mut EventCursor& c, EventTypeId t, int f){ if(c.nextIndex<=0 && b.slot0.occupied && b.slot0.type.value==t.value){ c.nextIndex=1; return b.slot0.payload.value; } if(c.nextIndex<=1 && b.slot1.occupied && b.slot1.type.value==t.value){ c.nextIndex=2; return b.slot1.payload.value; } return f; }
enum ActuationStatus { Empty, Pending, Completed, Failed, }; struct ActuationSlot { ActuationId id; ActuationStatus status; Reason reason; bool occupied; }; struct ActuatorHost { int nextId; ActuationSlot slot0; ActuationSlot slot1; ActuationSlot slot2; ActuationSlot slot3; }; struct ActuationDecision { bool allowed; Reason reason; }; struct ActuationDispatchResult { ActuationId id; bool accepted; bool completed; bool ok; Reason reason; };
ActuationSlot actuationEmptySlot(){ return ActuationSlot { id:ActuationId { value:0 }, status:ActuationStatus::Empty, reason:Reason { code:0 }, occupied:false }; } ActuatorHost actuatorHostEmpty(){ return ActuatorHost { nextId:1, slot0:actuationEmptySlot(), slot1:actuationEmptySlot(), slot2:actuationEmptySlot(), slot3:actuationEmptySlot() }; } ActuationDecision actuationAllow(){ return ActuationDecision { allowed:true, reason:Reason { code:0 } }; } ActuationDispatchResult actuatorDispatch(mut ActuatorHost& h, ActuationDecision d){ ActuationId id=ActuationId { value:h.nextId }; h.nextId=h.nextId+1; h.slot0=ActuationSlot { id:id, status:ActuationStatus::Pending, reason:d.reason, occupied:true }; return ActuationDispatchResult { id:id, accepted:true, completed:false, ok:true, reason:d.reason }; } void actuatorComplete(mut ActuatorHost& h, ActuationId id, Reason r){ if(h.slot0.occupied && h.slot0.id.value==id.value){ h.slot0.status=ActuationStatus::Completed; h.slot0.reason=r; return; } } ActuationStatus actuatorStatus(ActuatorHost h, ActuationId id){ if(h.slot0.occupied && h.slot0.id.value==id.value){ return h.slot0.status; } return ActuationStatus::Empty; } int actuationStatusCode(ActuationStatus s){ match(s){ ActuationStatus::Empty=>{return 0;} ActuationStatus::Pending=>{return 1;} ActuationStatus::Completed=>{return 3;} ActuationStatus::Failed=>{return 4;} } }
enum TraceEventKind { Empty, Enter, Exit, }; struct TraceEvent { TraceEventKind kind; StateId from; StateId to; Reason reason; int tick; bool occupied; }; struct TraceRecorder { int count; TraceEvent event0; TraceEvent event1; TraceEvent event2; TraceEvent event3; }; TraceEvent traceEmptyEvent(){ return TraceEvent { kind:TraceEventKind::Empty, from:StateId { value:0 }, to:StateId { value:0 }, reason:Reason { code:0 }, tick:0, occupied:false }; } TraceRecorder traceRecorderEmpty(){ return TraceRecorder { count:0, event0:traceEmptyEvent(), event1:traceEmptyEvent(), event2:traceEmptyEvent(), event3:traceEmptyEvent() }; } void traceEnter(mut TraceRecorder& r, StateId s, int tick, Reason reason){ r.event0=TraceEvent { kind:TraceEventKind::Enter, from:s, to:s, reason:reason, tick:tick, occupied:true }; r.count=r.count+1; } TraceEvent traceAt(TraceRecorder r, int i){ if(i==0){return r.event0;} return r.event1; } int traceEventKindCode(TraceEvent e){ match(e.kind){ TraceEventKind::Empty=>{return 0;} TraceEventKind::Enter=>{return 1;} TraceEventKind::Exit=>{return 2;} } }
struct Mind { int active; }; struct Agent { AgentId id; Memory memory; Mind mind; }; struct World { Clock clock; Memory memory; };
struct KernelCheckpoint { World world; Agent agent; EventBus events; ActuatorHost actuator; TraceRecorder trace; int rngSeed; bool occupied; };
KernelCheckpoint checkpointCapture(World w, Agent a, EventBus e, ActuatorHost ac, TraceRecorder t, int seed){ return KernelCheckpoint { world:w, agent:a, events:e, actuator:ac, trace:t, rngSeed:seed, occupied:true }; }
void checkpointRequireOccupied(KernelCheckpoint c){ if(!c.occupied){ panic("DragonGod.Checkpoint empty restore"); } } void checkpointRestoreWorld(mut World& w, KernelCheckpoint c){ checkpointRequireOccupied(c); w=c.world; } void checkpointRestoreAgent(mut Agent& a, KernelCheckpoint c){ checkpointRequireOccupied(c); a=c.agent; } void checkpointRestoreEvents(mut EventBus& e, KernelCheckpoint c){ checkpointRequireOccupied(c); e=c.events; } void checkpointRestoreActuator(mut ActuatorHost& a, KernelCheckpoint c){ checkpointRequireOccupied(c); a=c.actuator; } void checkpointRestoreTrace(mut TraceRecorder& t, KernelCheckpoint c){ checkpointRequireOccupied(c); t=c.trace; } int checkpointRngSeed(KernelCheckpoint c){ checkpointRequireOccupied(c); return c.rngSeed; } void checkpointRestoreAll(mut World& w, mut Agent& a, mut EventBus& e, mut ActuatorHost& ac, mut TraceRecorder& t, KernelCheckpoint c){ checkpointRequireOccupied(c); w=c.world; a=c.agent; e=c.events; ac=c.actuator; t=c.trace; }
enum ReplayEvent { Empty, WorldMemoryWriteInt(MemoryKeyInt key, int value), AgentMemoryWriteInt(MemoryKeyInt key, int value), EventPushInt(EventTypeId eventType, int value), RngSeed(int seed), }; struct ReplayLog { int count; ReplayEvent event0; ReplayEvent event1; ReplayEvent event2; ReplayEvent event3; }; struct ReplayDriver { int cursor; World world; Agent agent; EventBus events; ActuatorHost actuator; TraceRecorder trace; int rngSeed; }; ReplayLog replayLogEmpty(){ return ReplayLog { count:0, event0:ReplayEvent::Empty, event1:ReplayEvent::Empty, event2:ReplayEvent::Empty, event3:ReplayEvent::Empty }; } void replayPush(mut ReplayLog& l, ReplayEvent e){ if(l.count==0){l.event0=e; l.count=1; return;} if(l.count==1){l.event1=e; l.count=2; return;} } ReplayEvent replayAt(ReplayLog l, int i){ if(i==0){return l.event0;} return l.event1; } ReplayDriver replayDriverEmpty(){ return ReplayDriver { cursor:0, world:World { clock:Clock { tick:0 }, memory:memoryEmpty() }, agent:Agent { id:AgentId { value:0 }, memory:memoryEmpty(), mind:Mind { active:0 } }, events:eventBusEmpty(), actuator:actuatorHostEmpty(), trace:traceRecorderEmpty(), rngSeed:0 }; } bool replayApplyNext(mut ReplayDriver& d, ReplayLog l){ if(d.cursor>=l.count){return false;} ReplayEvent e=replayAt(l,d.cursor); d.cursor=d.cursor+1; match(e){ ReplayEvent::Empty=>{return true;} ReplayEvent::WorldMemoryWriteInt(k,v)=>{memoryWrite(d.world.memory&,k,v); return true;} ReplayEvent::AgentMemoryWriteInt(k,v)=>{memoryWrite(d.agent.memory&,k,v); return true;} ReplayEvent::EventPushInt(t,v)=>{discard eventPush(d.events&,t,eventPayloadInt(v)); return true;} ReplayEvent::RngSeed(seed)=>{d.rngSeed=seed; return true;} } } int replayApplyAll(mut ReplayDriver& d, ReplayLog l){ int n=0; if(replayApplyNext(d&,l)){n=n+1;} if(replayApplyNext(d&,l)){n=n+1;} return n; }
int main(){ ReplayLog l=replayLogEmpty(); replayPush(l&, ReplayEvent::WorldMemoryWriteInt(MemoryKeyInt { id:4 }, 66)); replayPush(l&, ReplayEvent::RngSeed(123)); ReplayDriver d=replayDriverEmpty(); if(replayApplyAll(d&,l)!=2){return 1;} KernelCheckpoint c=checkpointCapture(d.world,d.agent,d.events,d.actuator,d.trace,d.rngSeed); memoryWrite(d.world.memory&, MemoryKeyInt { id:4 }, 1); d.rngSeed=0; checkpointRestoreWorld(d.world&,c); return memoryRead(d.world.memory,MemoryKeyInt { id:4 },0)+checkpointRngSeed(c)-189; }

