# name: phase20 DragonGod automata signal
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId {
    int value;
};

struct ActuationId {
    int value;
};

struct Reason {
    int code;
};

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

int main() {
    Reason reason = Reason { code: 42 };
    AutomataSignal signal = AutomataSignal::Succeed(reason);
    match (signal) {
        AutomataSignal::None => return 0;
        AutomataSignal::Goto(target, value) => return target.value + value.code;
        AutomataSignal::Succeed(value) => return value.code;
        AutomataSignal::Fail(value) => return value.code;
        AutomataSignal::Act(id) => return id.value;
        AutomataSignal::AwaitActuation(id) => return id.value;
    }
}

=== run ===
exit_code: 42
