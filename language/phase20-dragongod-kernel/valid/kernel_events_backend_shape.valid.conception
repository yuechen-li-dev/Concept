# name: kernel_events_backend_shape.valid.conception
# phase: backend-c
# expect: pass

=== source ===
module Main;
struct EventTypeId { int value; };
struct EventId { int value; };
struct EventPayloadInt { int value; };
struct EventSlot { EventId id; EventTypeId type; EventPayloadInt payload; bool occupied; };
struct EventCursor { int nextIndex; };
struct EventBus { int nextId; FixedBuffer<EventSlot, 4> slots; };
EventTypeId eventType(int value) { return EventTypeId { value: value }; }
EventPayloadInt eventPayloadInt(int value) { return EventPayloadInt { value: value }; }
EventBus eventBusEmpty() { return EventBus { nextId: 1, slots: fixedBufferEmpty<EventSlot, 4>() }; }
EventCursor eventCursorStart() { return EventCursor { nextIndex: 0 }; }
EventCursor eventTailCursor(EventBus bus) { return EventCursor { nextIndex: Len(bus.slots) }; }
EventId eventPush(mut EventBus& bus, EventTypeId type, EventPayloadInt payload) { EventId id = EventId { value: bus.nextId }; bus.nextId = bus.nextId + 1; if (Len(bus.slots) >= Capacity(bus.slots)) { panic("DragonGod.Events capacity exceeded"); } fixedBufferAppend(bus.slots, EventSlot { id: id, type: type, payload: payload, occupied: true }); return id; }
bool eventSlotMatches(EventSlot slot, EventTypeId type) { return slot.occupied && slot.type.value == type.value; }
int eventReadNextInt(EventBus bus, mut EventCursor& cursor, EventTypeId type, int fallback) { if (cursor.nextIndex <= 0 && Len(bus.slots) > 0) { if (eventSlotMatches(bus.slots[0], type)) { cursor.nextIndex = 1; return bus.slots[0].payload.value; } } if (cursor.nextIndex <= 1 && Len(bus.slots) > 1) { if (eventSlotMatches(bus.slots[1], type)) { cursor.nextIndex = 2; return bus.slots[1].payload.value; } } cursor.nextIndex = Len(bus.slots); return fallback; }
int main() { EventBus bus = eventBusEmpty(); EventTypeId t = eventType(1); EventId id = eventPush(bus&, t, eventPayloadInt(42)); EventCursor cursor = eventCursorStart(); if (id.value != 1) { return 1; } if (Len(bus.slots) != 1) { return 2; } return eventReadNextInt(bus, cursor&, t, 0) - 42; }

