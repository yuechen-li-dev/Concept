# name: phase20 DG2 signal fail machine run
# phase: run
# expect: pass

=== source ===
module Main;

struct StateId { int value; };
struct ActuationId { int value; };
struct Reason { int code; };

enum AutomataSignal {
    None,
    Goto(StateId target, Reason reason),
    Succeed(Reason reason),
    Fail(Reason reason),
    Act(ActuationId id),
    AwaitActuation(ActuationId id),
};

machine FailNow -> AutomataSignal { state Start { return AutomataSignal::Fail(Reason { code: 13 }); } }
int main() { FailNow m = FailNow(); Step(m); AutomataSignal signal = Result(m); match (signal) { AutomataSignal::Fail(reason) => return reason.code; AutomataSignal::None => return 99; AutomataSignal::Goto(target, reason) => return target.value + reason.code; AutomataSignal::Succeed(reason) => return reason.code; AutomataSignal::Act(id) => return id.value; AutomataSignal::AwaitActuation(id) => return id.value; } }


=== run ===
exit_code: 13
