# name: store id type mismatch
# phase: check
# check: hir
# expect: fail

=== source ===
module Example;

struct ExprId {
    int index;
};

struct TypeId {
    int index;
};

noalloc int UseExprId(ExprId id) {
    TypeId t = id;
    return t.index;
}

=== diagnostics ===
CON0029 error: local initializer type does not match declared type

