# name: expr store single entry
# phase: check
# check: hir
# expect: pass

=== source ===
module Example;

marker concept Copy<T>;

struct ExprId {
    int index;
};

impl Copy<ExprId>;

struct Expr {
    int kind;
    int value;
};

impl Copy<Expr>;

struct ExprStore {
    int count;
    Expr first;
};

noalloc ExprId FirstExprId() {
    return ExprId {
        index: 0,
    };
}

noalloc ExprStore AddFirst(Expr expr) {
    return ExprStore {
        count: 1,
        first: expr,
    };
}

noalloc Expr GetFirst(ExprStore store, ExprId id) {
    return store.first;
}

