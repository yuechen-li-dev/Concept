module Main;

int main() {
    Option<int> maybe = optionSome<int>(3);
    int fallback = optionUnwrapOr(maybe, 1);
    if (optionIsNone(maybe)) {
        return 99;
    }

    match maybe {
        Some(value) => return value + fallback;
        None => return 0;
    }
}

